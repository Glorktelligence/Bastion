{
  "name": "bastion",
  "private": true,
  "version": "0.5.7",
  "description": "Human-AI Secure Messaging Protocol",
  "license": "Apache-2.0",
  "author": "Harry Smith <harry@glorktelligence.co.uk>",
  "repository": {
    "type": "git",
    "url": "https://git.glorktelligence.co.uk/glorktelligence/bastion"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "node run-all-tests.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "clean": "pnpm -r clean",
    "version:sync": "node scripts/sync-version.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome"],
    "overrides": {
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5",
      "node-forge": ">=1.4.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  }
}
