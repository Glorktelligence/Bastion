# =============================================================================
# Bastion Environment Variables
# Copy to .env and fill in values before deployment.
# =============================================================================

# ---------------------------------------------------------------------------
# Relay Server (start-relay.mjs)
# ---------------------------------------------------------------------------
BASTION_RELAY_PORT=9443
BASTION_TLS_CERT=./certs/relay-cert.pem
BASTION_TLS_KEY=./certs/relay-key.pem
BASTION_JWT_SECRET=                          # REQUIRED — random 256-bit key (auto-generated if unset)
BASTION_JWT_ISSUER=bastion-relay
BASTION_AUDIT_DB=/var/lib/bastion/audit.db
BASTION_EXTENSIONS_DIR=./extensions
BASTION_QUARANTINE_MAX_ENTRIES=100
BASTION_QUARANTINE_TIMEOUT_MS=3600000
BASTION_PURGE_INTERVAL_MS=60000
BASTION_PROJECT_SYNC_MAX_CONTENT=1048576     # Max project file content size (bytes, default 1MB)

# Admin panel
BASTION_ADMIN_PORT=9444
BASTION_ADMIN_HOST=127.0.0.1                 # Must be private address — public binding refused
BASTION_ADMIN_CREDENTIALS_PATH=/var/lib/bastion/admin-credentials.json
# BASTION_ADMIN_USERNAME=admin
# BASTION_ADMIN_PASSWORD_HASH=               # scrypt hash — set via admin setup wizard
# BASTION_ADMIN_TOTP_SECRET=                 # TOTP secret — set via admin setup wizard
BASTION_ADMIN_SESSION_TIMEOUT=1800

# AI Disclosure (opt-in)
BASTION_DISCLOSURE_ENABLED=false
# BASTION_DISCLOSURE_TEXT=You are interacting with an AI system powered by {provider} ({model}).
# BASTION_DISCLOSURE_STYLE=info
# BASTION_DISCLOSURE_POSITION=banner
# BASTION_DISCLOSURE_DISMISSIBLE=true

# ---------------------------------------------------------------------------
# AI Client (start-ai-client.mjs)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=                           # REQUIRED — Anthropic API key
BASTION_RELAY_URL=wss://10.0.30.10:9443
BASTION_AI_CLIENT_ID=ai-client-001
BASTION_AI_DISPLAY_NAME=Claude (Bastion)
BASTION_PROVIDER_ID=anthropic-bastion
BASTION_PROVIDER_NAME=Anthropic (Bastion Official)
BASTION_MAX_TOKENS=4096
BASTION_TEMPERATURE=1.0
BASTION_API_ENDPOINT=https://api.anthropic.com
BASTION_API_VERSION=2023-06-01
BASTION_TIMEOUT=120000
BASTION_STREAMING=true
BASTION_TLS_REJECT_UNAUTHORIZED=true         # Set to false for self-signed certs

# Adapter models (override defaults)
BASTION_SONNET_MODEL=claude-sonnet-4-6
BASTION_SONNET_PRICING_INPUT=3
BASTION_SONNET_PRICING_OUTPUT=15
BASTION_SONNET_MAX_CONTEXT=1000000
BASTION_HAIKU_MODEL=claude-haiku-4-5-20251001
BASTION_HAIKU_PRICING_INPUT=1
BASTION_HAIKU_PRICING_OUTPUT=5
BASTION_HAIKU_MAX_CONTEXT=200000
BASTION_OPUS_MODEL=claude-opus-4-6
BASTION_OPUS_PRICING_INPUT=5
BASTION_OPUS_PRICING_OUTPUT=25
BASTION_OPUS_MAX_TOKENS=8192
BASTION_OPUS_MAX_CONTEXT=1000000

# Data paths
BASTION_MEMORIES_DB=/var/lib/bastion/memories.db
BASTION_CONVERSATIONS_DB=/var/lib/bastion/conversations.db
BASTION_USAGE_DB=/var/lib/bastion/usage.db
BASTION_PROJECT_DIR=/var/lib/bastion/project
BASTION_SKILLS_DIR=./skills
BASTION_USER_CONTEXT_PATH=/var/lib/bastion/user-context.md
BASTION_OPERATOR_CONTEXT_PATH=/var/lib/bastion/operator-context.md
BASTION_TOKEN_BUDGET=1000000
BASTION_CONVERSATION_BUDGET=80000
BASTION_OPERATOR_CONTEXT_BUDGET=2000
BASTION_USER_CONTEXT_BUDGET=20000

# File handling
BASTION_INTAKE_DIR=/var/lib/bastion/intake
BASTION_OUTBOUND_DIR=/var/lib/bastion/outbound
BASTION_INTAKE_MAX_FILES=50
BASTION_OUTBOUND_MAX_FILES=50
BASTION_FILE_PURGE_TIMEOUT_MS=3600000

# Compaction
BASTION_MAX_PROMPT_MEMORIES=20
BASTION_COMPACTION_TRIGGER_PERCENT=80
BASTION_COMPACTION_KEEP_RECENT=50

# Extensions
BASTION_EXTENSIONS_DATA=/var/lib/bastion/extensions  # Extension state data directory (one subdir per namespace)

# Challenge Me More
BASTION_CHALLENGE_CONFIG=/var/lib/bastion/challenge-config.json

# Budget Guard
BASTION_BUDGET_DB=/var/lib/bastion/budget.db
BASTION_BUDGET_CONFIG=/var/lib/bastion/budget-config.json

# MCP Providers (dynamic: BASTION_MCP_<NAME>_URL / BASTION_MCP_<NAME>_API_KEY)
# BASTION_MCP_WEATHER_URL=ws://localhost:8080
# BASTION_MCP_WEATHER_API_KEY=your-key-here

# ---------------------------------------------------------------------------
# Admin UI (start-admin-ui.mjs)
# ---------------------------------------------------------------------------
BASTION_ADMIN_UI_PORT=9445
