{
  "name": "@bastion/relay",
  "version": "0.7.0",
  "description": "WebSocket relay server with TLS, routing, audit, and quarantine for Project Bastion",
  "license": "Apache-2.0",
  "author": "Harry Smith <harry@glorktelligence.co.uk>",
  "type": "module",
  "main": "./dist/index.js",
