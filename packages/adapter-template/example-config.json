{
  "_description": "Example adapter configuration. Copy and modify for your provider. API keys come from environment variables — never put them here.",
  "providerId": "my-custom-adapter",
  "providerName": "My Custom AI Provider",
  "model": "my-model-v1",
  "supportedModels": ["my-model-v1", "my-model-lite"],
  "apiKeyEnvVar": "MY_PROVIDER_API_KEY",
  "apiBaseUrl": "https://api.my-provider.com/v1",
  "maxTokens": 4096,
  "temperature": 1.0,
  "timeoutMs": 120000,
  "systemPrompt": "You are a helpful AI assistant.",
  "pricing": {
    "inputPerMTok": 2,
    "outputPerMTok": 10
  },
  "capabilities": {
    "conversation": true,
    "taskExecution": true,
    "fileTransfer": false,
    "streaming": false,
    "webSearch": false,
    "toolUse": false,
    "vision": false,
    "maxContextTokens": 128000
  },
  "roles": ["default", "conversation", "task"]
}
