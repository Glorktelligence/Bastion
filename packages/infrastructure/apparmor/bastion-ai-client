# AppArmor profile: Bastion AI Client
#
# Mandatory access control for the Bastion AI client process.
# This profile restricts filesystem, network, and capability access
# at the kernel level — even if the Node.js process is compromised,
# it cannot escape these boundaries.
#
# Installation:
#   sudo cp bastion-ai-client /etc/apparmor.d/bastion-ai-client
#   sudo apparmor_parser -r /etc/apparmor.d/bastion-ai-client
#
# Test in complain mode first:
#   sudo aa-complain /etc/apparmor.d/bastion-ai-client
#   # Run AI client, check /var/log/syslog for ALLOWED entries
#   # Once clean, switch to enforce:
#   sudo aa-enforce /etc/apparmor.d/bastion-ai-client
#
# Check status:
#   sudo aa-status | grep bastion
#
