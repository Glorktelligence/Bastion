{
  "name": "@bastion/relay-admin-ui",
  "version": "0.8.0",
  "description": "SvelteKit admin panel for the Bastion relay — provider management, monitoring, and configuration",
  "license": "Apache-2.0",
  "author": "Harry Smith <harry@glorktelligence.co.uk>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite dev",
    "build": "tsc",
    "build:app": "vite build",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist build .svelte-kit",
    "test:admin-ui": "node trace-test.mjs"
  },
  "dependencies": {
    "@bastion/protocol": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@types/node": "^25.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
