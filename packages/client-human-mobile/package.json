{
  "name": "@bastion/client-human-mobile",
  "version": "0.8.0",
  "description": "React Native mobile client for Project Bastion — human-side messaging, challenge review, and file transfers",
  "license": "Apache-2.0",
  "author": "Harry Smith <harry@glorktelligence.co.uk>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bastion/protocol": "workspace:*",
    "@bastion/crypto": "workspace:*",
    "react": "^18.3.0",
    "react-native": "^0.76.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "react-native-screens": "^4.0.0",
    "react-native-safe-area-context": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.0",
    "@react-native/metro-config": "^0.76.0",
    "typescript": "^5.7.0"
  }
}
