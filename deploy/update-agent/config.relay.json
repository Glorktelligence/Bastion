{
  "relayUrl": "wss://127.0.0.1:9443",
  "agentId": "updater-relay",
  "agentName": "Relay Update Agent",
  "component": "relay",
  "buildPath": "/opt/bastion",
  "buildUser": "bastion",
  "services": ["bastion-relay", "bastion-admin-ui"],
  "buildSteps": [
    { "type": "git_pull" },
    { "type": "pnpm_install" },
    { "type": "pnpm_build", "filter": "@bastion/protocol" },
    { "type": "pnpm_build", "filter": "@bastion/crypto" },
    { "type": "pnpm_build", "filter": "@bastion/relay" },
    { "type": "pnpm_build", "filter": "@bastion/relay-admin-ui" },
    { "type": "pnpm_build", "filter": "@bastion/update-agent" }
  ],
  "tls": {
    "caCertPath": "/opt/bastion/certs/relay-cert.pem"
  },
  "commandTimeoutMs": 300000
}
